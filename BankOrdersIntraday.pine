//@version=5
// =============================================================================
//  HEAVY INSTITUTIONAL ZONES – Intraday (Strongest Only)
//  Bank Buying / Bank Selling Order Blocks + Market Turning Points
//  Confluence-scored, non-repainting, confirmed-bar logic.
//  Best on 5m / 15m intraday.
// =============================================================================
indicator("HEAVY INSTITUTIONAL ZONES – Intraday",
     shorttitle="HEAVY INST ZONES",
     overlay=true,
     max_boxes_count=500,
     max_lines_count=500,
     max_labels_count=500)

// -----------------------------------------------------------------------------
//  INPUTS
// -----------------------------------------------------------------------------
gDet = "Detection Engine"
atrLen   = input.int(14,    "ATR Length",                  minval=2,    group=gDet)
displAtr = input.float(2.0, "Displacement: Range ≥ ATR ×", minval=0.8,  step=0.1, group=gDet)
bodyR    = input.float(0.70,"Min Body / Range Ratio",      minval=0.30, maxval=1.0, step=0.02, group=gDet)
volLen   = input.int(20,    "Volume MA Length",            minval=2,    group=gDet)
volX     = input.float(1.8, "Volume Spike × MA",           minval=1.0,  step=0.1, group=gDet)
swingLen = input.int(5,     "Swing / Pivot Length",        minval=2,    maxval=20, group=gDet)
wickR    = input.float(0.35,"Min Sweep Wick / Range",      minval=0.10, step=0.05, group=gDet)
htfTF    = input.timeframe("60", "HTF Resolution",         group=gDet)

gStr = "Strength Filter (HEAVY = strongest zones only)"
minScore   = input.int(5,   "Minimum Strength Score (out of 6)", minval=1, maxval=6, group=gStr,
     tooltip="A zone must satisfy at least this many confluences to be plotted. 6 = institutional-grade only.")
heavyScore = input.int(6,   "Institutional ★ Threshold",         minval=2, maxval=6, group=gStr,
     tooltip="Zones at or above this score are highlighted as ★ INSTITUTIONAL.")
sessFilter = input.bool(false,"Restrict to Session",              group=gStr)
sessTF     = input.session("0915-1500","Session (exchange time)", group=gStr)

gZone = "Zone Behaviour"
intradayOnly = input.bool(true, "Intraday Only (auto-expire next day)", group=gZone)
extendRight  = input.bool(true, "Extend Zones to Live Edge",            group=gZone)
freshOnly    = input.bool(true, "Fade After First Touch",               group=gZone)
killOnClose  = input.bool(true, "Invalidate when Close beyond zone",    group=gZone)
mergeOverlap = input.bool(true, "Merge Overlapping Same-side Zones",    group=gZone)
maxPerSide   = input.int(5,     "Max Active Zones per Side",  minval=1, maxval=15, group=gZone)
zoneLabel    = input.bool(true, "Show Zone Labels",                     group=gZone)

gTP = "Market Turning Points"
showTP       = input.bool(true,  "Show Turning Points",                 group=gTP)
tpRequireBOS = input.bool(false, "Only mark TP that produced BOS",      group=gTP)

gAlert = "Alerts"
aTouch = input.bool(true, "Alert on Zone Touch",                        group=gAlert)
aBreak = input.bool(true, "Alert on Zone Invalidation",                 group=gAlert)
aReject= input.bool(true, "Alert on Rejection from Zone",               group=gAlert)
aHeavy = input.bool(true, "Alert on NEW Institutional Zone",            group=gAlert)

gStyle = "Visual Design"
buyFill    = input.color(color.new(#a020f0, 80), "Buy Zone Fill",        group=gStyle)
buyHeavy   = input.color(color.new(#a020f0, 60), "Buy Zone Fill ★",      group=gStyle)
sellFill   = input.color(color.new(#ff1f6d, 80), "Sell Zone Fill",       group=gStyle)
sellHeavy  = input.color(color.new(#ff1f6d, 60), "Sell Zone Fill ★",     group=gStyle)
buyBord    = input.color(#a020f0, "Buy Border",                          group=gStyle)
sellBord   = input.color(#ff1f6d, "Sell Border",                         group=gStyle)
fadedFill  = input.color(color.new(color.gray, 90), "Faded Fill",        group=gStyle)
buyTxt     = input.string("BANK BUYING ORDER",  "Buy Label",             group=gStyle)
sellTxt    = input.string("BANK SELLING ORDER", "Sell Label",            group=gStyle)
heavyTag   = input.string("★ INSTITUTIONAL",   "Heavy-Zone Suffix",      group=gStyle)
tpHighCol  = input.color(#ff3333, "Swing-High Dot",                      group=gStyle)
tpLowCol   = input.color(#22ff66, "Swing-Low  Dot",                      group=gStyle)

// -----------------------------------------------------------------------------
//  CORE METRICS
// -----------------------------------------------------------------------------
atrV   = ta.atr(atrLen)
volMa  = ta.sma(volume, volLen)
rng    = high - low
bodySz = math.abs(close - open)
upWick = high - math.max(close, open)
dnWick = math.min(close, open) - low

bigRange = rng > atrV * displAtr
bigBody  = bodySz >= rng * bodyR
volSpike = volume >= volMa * volX
bull     = close > open
bear     = close < open

inSess = not sessFilter or not na(time(timeframe.period, sessTF))

// -----------------------------------------------------------------------------
//  STRUCTURE: BOS / CHOCH
// -----------------------------------------------------------------------------
ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow (low,  swingLen, swingLen)

var float lastPH = na
var float lastPL = na
var int   bias   = 0

if not na(ph)
    lastPH := ph
if not na(pl)
    lastPL := pl

bosUp = not na(lastPH) and close > lastPH and close[1] <= lastPH
bosDn = not na(lastPL) and close < lastPL and close[1] >= lastPL
chUp  = bosUp and bias == -1
chDn  = bosDn and bias ==  1
if bosUp
    bias := 1
if bosDn
    bias := -1
bullStruct = bosUp or chUp
bearStruct = bosDn or chDn

// -----------------------------------------------------------------------------
//  FAIR VALUE GAP (3-bar imbalance)
// -----------------------------------------------------------------------------
bullFVG = low  > high[2]
bearFVG = high < low[2]

// -----------------------------------------------------------------------------
//  HIGHER-TIMEFRAME TREND
// -----------------------------------------------------------------------------
htfClose = request.security(syminfo.tickerid, htfTF, close, lookahead=barmerge.lookahead_off)
htfOpen  = request.security(syminfo.tickerid, htfTF, open,  lookahead=barmerge.lookahead_off)
htfBull  = htfClose > htfOpen
htfBear  = htfClose < htfOpen

// -----------------------------------------------------------------------------
//  CONFLUENCE SCORING (0-6)
// -----------------------------------------------------------------------------
sweepBuy  = dnWick >= rng * wickR
sweepSell = upWick >= rng * wickR

buyScore =
   (bigRange   ? 1 : 0) +
   (bigBody    ? 1 : 0) +
   (volSpike   ? 1 : 0) +
   (bullFVG    ? 1 : 0) +
   (bullStruct ? 1 : 0) +
   ((htfBull and sweepBuy) ? 1 : 0)

sellScore =
   (bigRange   ? 1 : 0) +
   (bigBody    ? 1 : 0) +
   (volSpike   ? 1 : 0) +
   (bearFVG    ? 1 : 0) +
   (bearStruct ? 1 : 0) +
   ((htfBear and sweepSell) ? 1 : 0)

base   = barstate.isconfirmed and inSess
isBuy  = base and bull and buyScore  >= minScore
isSell = base and bear and sellScore >= minScore
buyHeavyZone  = isBuy  and buyScore  >= heavyScore
sellHeavyZone = isSell and sellScore >= heavyScore

// -----------------------------------------------------------------------------
//  ZONE STORAGE (UDT)
// -----------------------------------------------------------------------------
type Zone
    box   bx
    label lbl
    float top
    float bot
    int   created
    int   score
    bool  isBuy
    bool  isHeavy
    bool  touched
    bool  alive

var array<Zone> zones = array.new<Zone>()

f_clear(Zone z) =>
    box.delete(z.bx)
    if not na(z.lbl)
        label.delete(z.lbl)
    true

f_draw(bool _buy, bool _heavy, int _score, float _t, float _b) =>
    color  fill   = _buy ? (_heavy ? buyHeavy  : buyFill ) : (_heavy ? sellHeavy : sellFill)
    color  border = _buy ? buyBord : sellBord
    int    bw     = _heavy ? 3 : 2
    int    rightX = bar_index + 30
    box    bx     = box.new(left=bar_index, top=_t, right=rightX, bottom=_b,
                     border_color=border, border_width=bw, bgcolor=fill,
                     extend=extendRight ? extend.right : extend.none)
    label  lb     = na
    if zoneLabel
        string baseTxt = _buy ? buyTxt : sellTxt
        string tag     = _heavy ? "  " + heavyTag : ""
        string scr     = "  (" + str.tostring(_score) + "/6)"
        lb := label.new(bar_index + 5, (_t + _b) / 2.0, baseTxt + tag + scr,
             style=label.style_none, textcolor=color.white, size=size.small)
    Zone.new(bx, lb, _t, _b, bar_index, _score, _buy, _heavy, false, true)

f_capSide(bool _buy) =>
    int cnt = 0
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            zi = array.get(zones, i)
            if zi.alive and zi.isBuy == _buy
                cnt += 1
    if cnt > maxPerSide and array.size(zones) > 0
        int idxWeakest = -1
        int minSc      = 99
        for i = 0 to array.size(zones) - 1
            zj = array.get(zones, i)
            if zj.alive and zj.isBuy == _buy
                if zj.score < minSc
                    minSc := zj.score
                    idxWeakest := i
        if idxWeakest >= 0
            zk = array.get(zones, idxWeakest)
            zk.alive := false
            f_clear(zk)
            array.set(zones, idxWeakest, zk)
    true

f_addZone(bool _buy, bool _heavy, int _score, float _t, float _b) =>
    bool merged = false
    if mergeOverlap and array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            zi = array.get(zones, i)
            if zi.alive and zi.isBuy == _buy and not zi.touched
                bool overlap = _t >= zi.bot and _b <= zi.top
                if overlap
                    float nt = math.max(zi.top, _t)
                    float nb = math.min(zi.bot, _b)
                    box.set_top(zi.bx, nt)
                    box.set_bottom(zi.bx, nb)
                    zi.top   := nt
                    zi.bot   := nb
                    zi.score := math.max(zi.score, _score)
                    if _heavy and not zi.isHeavy
                        zi.isHeavy := true
                        box.set_border_width(zi.bx, 3)
                        box.set_bgcolor(zi.bx, _buy ? buyHeavy : sellHeavy)
                    array.set(zones, i, zi)
                    merged := true
                    break
    if not merged
        Zone z = f_draw(_buy, _heavy, _score, _t, _b)
        array.push(zones, z)
        f_capSide(_buy)
    true

// -----------------------------------------------------------------------------
//  CREATE BANK ORDERS
// -----------------------------------------------------------------------------
var bool newHeavyAlert = false
newHeavyAlert := false

if isBuy
    topZ = math.max(open, close)
    botZ = low
    f_addZone(true, buyHeavyZone, buyScore, topZ, botZ)
    if buyHeavyZone
        newHeavyAlert := true

if isSell
    topZ = high
    botZ = math.min(open, close)
    f_addZone(false, sellHeavyZone, sellScore, topZ, botZ)
    if sellHeavyZone
        newHeavyAlert := true

// -----------------------------------------------------------------------------
//  ZONE LIFECYCLE
// -----------------------------------------------------------------------------
isNewDay = ta.change(time("D")) != 0

var bool touchAlert  = false
var bool breakAlert  = false
var bool rejectAlert = false
touchAlert  := false
breakAlert  := false
rejectAlert := false

if array.size(zones) > 0
    for i = 0 to array.size(zones) - 1
        z = array.get(zones, i)
        if not z.alive
            continue

        if intradayOnly and isNewDay and bar_index > z.created
            z.alive := false
            f_clear(z)
            array.set(zones, i, z)
            continue

        invalid = false
        if killOnClose
            if z.isBuy and close < z.bot
                invalid := true
            if (not z.isBuy) and close > z.top
                invalid := true
        if invalid
            z.alive := false
            box.set_bgcolor(z.bx, color.new(color.gray, 88))
            box.set_border_color(z.bx, color.new(color.gray, 60))
            if not na(z.lbl)
                label.delete(z.lbl)
            array.set(zones, i, z)
            breakAlert := true
            continue

        bool insideBuy  = z.isBuy and low <= z.top and high >= z.bot
        bool insideSell = (not z.isBuy) and high >= z.bot and low <= z.top
        bool inside     = insideBuy or insideSell
        if inside and not z.touched
            z.touched  := true
            touchAlert := true
            bool rejBuy  = z.isBuy and close > open and dnWick >= rng * wickR
            bool rejSell = (not z.isBuy) and close < open and upWick >= rng * wickR
            if rejBuy or rejSell
                rejectAlert := true
            array.set(zones, i, z)

        if freshOnly and z.touched
            box.set_bgcolor(z.bx, fadedFill)

// -----------------------------------------------------------------------------
//  MARKET TURNING POINTS
// -----------------------------------------------------------------------------
bool phPlot = not na(ph) and (not tpRequireBOS or bosDn)
bool plPlot = not na(pl) and (not tpRequireBOS or bosUp)

plotshape(showTP and phPlot, title="Swing High",
     style=shape.circle, location=location.abovebar, color=tpHighCol,
     size=size.tiny, offset=-swingLen)
plotshape(showTP and plPlot, title="Swing Low",
     style=shape.circle, location=location.belowbar, color=tpLowCol,
     size=size.tiny, offset=-swingLen)

// -----------------------------------------------------------------------------
//  ALERTS
// -----------------------------------------------------------------------------
if aTouch and touchAlert
    alert("INSTITUTIONAL ZONE touched – watch for reaction", alert.freq_once_per_bar)
if aReject and rejectAlert
    alert("INSTITUTIONAL ZONE rejection – high-probability entry", alert.freq_once_per_bar)
if aBreak and breakAlert
    alert("INSTITUTIONAL ZONE invalidated – zone broken", alert.freq_once_per_bar)
if aHeavy and newHeavyAlert
    alert("NEW ★ INSTITUTIONAL zone formed", alert.freq_once_per_bar)

alertcondition(touchAlert,    title="Zone Touch",          message="INSTITUTIONAL ZONE touched")
alertcondition(rejectAlert,   title="Zone Rejection",      message="INSTITUTIONAL ZONE rejection")
alertcondition(breakAlert,    title="Zone Invalidation",   message="INSTITUTIONAL ZONE invalidated")
alertcondition(newHeavyAlert, title="New ★ Institutional", message="NEW ★ INSTITUTIONAL zone")

// =============================================================================
//  END
// =============================================================================
