//@version=5
// =============================================================================
//  Institutional Supply & Demand Zones  -  NSE Intraday (Nifty 500)
//  Pine Script v5  |  Non-repainting  |  Overlay
//  Every multi-arg call is on a single line to avoid continuation issues.
// =============================================================================
indicator("Institutional Supply & Demand Zones [NSE Intraday]", shorttitle="INST S/D", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// -----------------------------------------------------------------------------
// INPUTS
// -----------------------------------------------------------------------------
gCore   = "Core Detection"
atrLen  = input.int(14,    "ATR Length", minval=2, group=gCore)
atrMult = input.float(1.5, "Displacement: Range > ATR x", minval=0.5, step=0.1, group=gCore)
bodyPct = input.float(0.55,"Min Body / Range Ratio (displacement)", minval=0.1, maxval=1.0, step=0.05, group=gCore)
volLen  = input.int(20,    "Volume MA Length", minval=2, group=gCore)
volMult = input.float(1.3, "Volume Spike x MA", minval=1.0, step=0.1, group=gCore)
pivLen  = input.int(5,     "Structure Pivot Length", minval=2, group=gCore)

gBase   = "Base Candle (zone origin)"
useBase     = input.bool(true,  "Anchor zones to base candle(s)", group=gBase, tooltip="Real institutional zones (Drop-Base-Rally / Rally-Base-Drop). Locks zones to where price actually returns instead of drifting above/below.")
maxBaseBars = input.int(3,      "Max base candles", minval=1, maxval=5, group=gBase)
baseBodyPct = input.float(0.5,  "Base: max body / range ratio", minval=0.1, maxval=1.0, step=0.05, group=gBase)
baseRngMult = input.float(0.85, "Base: max range vs ATR", minval=0.2, step=0.05, group=gBase)

gFlt    = "Confirmation Filters (score-based)"
useVol  = input.bool(true, "Volume Spike", group=gFlt)
useFVG  = input.bool(true, "Fair Value Gap (Imbalance)", group=gFlt)
useBOS  = input.bool(true, "Break of Structure / CHOCH", group=gFlt)
useWick = input.bool(true, "Liquidity Sweep Wick", group=gFlt)
wickPct = input.float(0.35,"Min Sweep Wick / Range", minval=0.05, step=0.05, group=gFlt)
minConf = input.int(2,     "Min Confirmations Required", minval=0, maxval=4, group=gFlt, tooltip="How many of the 4 filters above must pass. 0 = core only, 4 = strictest.")
noOverlap = input.bool(true,"Reject new zone if it overlaps an alive same-side zone", group=gFlt)

gConf   = "Confluence"
useVWAP = input.bool(false, "VWAP Side Alignment", group=gConf)
useEMA  = input.bool(false, "EMA 20 / 50 Trend", group=gConf)
usePDHL = input.bool(false, "Previous Day High / Low", group=gConf)
useCPR  = input.bool(false, "CPR Confluence", group=gConf)
useHTF  = input.bool(true,  "HTF Alignment for SUPER tag", group=gConf)
htfRes  = input.timeframe("60", "HTF Resolution", group=gConf)

gSess   = "Session (NSE Intraday)"
useSess = input.bool(true, "Detect Only In Session", group=gSess)
sessStr = input.session("0915-1500", "Active Session (Exchange TZ)", group=gSess)

gZone   = "Zone Behaviour"
intraOnly      = input.bool(true, "Auto-Expire On New Day", group=gZone)
freshOnly      = input.bool(true, "Fade Already-Tested Zones", group=gZone)
invalidOnClose = input.bool(true, "Invalidate If Close Beyond Zone", group=gZone)
extendRight    = input.bool(true, "Extend Zones Right", group=gZone)
showMid        = input.bool(true, "Show Equilibrium (50%)", group=gZone)
maxPerSide     = input.int(3, "Max Active Zones / Side", minval=1, maxval=20, group=gZone)

gEntry  = "Entry Markers"
showEntry = input.bool(true, "Show BUY / SELL Markers", group=gEntry)
showSLTP  = input.bool(true, "Plot SL / TP Levels", group=gEntry)
rrTarget  = input.float(2.0, "Risk : Reward Target", minval=1.0, step=0.5, group=gEntry)

gAlert  = "Alerts"
alertTouch = input.bool(true,  "Alert On First Touch", group=gAlert)
alertEntry = input.bool(true,  "Alert On Confirmed Entry", group=gAlert)
alertNear  = input.bool(false, "Pre-Alert When Price Near", group=gAlert)
nearPct    = input.float(0.25, "Near Buffer (x zone height)", minval=0.0, step=0.05, group=gAlert)

gStyle  = "Visual"
demFill  = input.color(color.new(#26a69a, 80), "Demand Fill", group=gStyle)
supFill  = input.color(color.new(#ef5350, 80), "Supply Fill", group=gStyle)
sDemFill = input.color(color.new(#00ff88, 55), "SUPER Demand Fill", group=gStyle)
sSupFill = input.color(color.new(#ff1744, 55), "SUPER Supply Fill", group=gStyle)
demEdge  = input.color(#26a69a, "Demand Border", group=gStyle)
supEdge  = input.color(#ef5350, "Supply Border", group=gStyle)
sDemEdge = input.color(#00ff88, "SUPER Demand Border", group=gStyle)
sSupEdge = input.color(#ff1744, "SUPER Supply Border", group=gStyle)
demTxt   = input.string("BANK BUYING ZONE",  "Demand Label", group=gStyle)
supTxt   = input.string("BANK SELLING ZONE", "Supply Label", group=gStyle)
showTxt  = input.bool(true, "Show Labels", group=gStyle)

// -----------------------------------------------------------------------------
// CORE BAR METRICS
// -----------------------------------------------------------------------------
atr    = ta.atr(atrLen)
volMa  = ta.sma(volume, volLen)
rng    = high - low
body   = math.abs(close - open)
upWick = high - math.max(close, open)
dnWick = math.min(close, open) - low

bullBar = close > open
bearBar = close < open
inSess  = not useSess or not na(time(timeframe.period, sessStr))

displ   = rng > atr * atrMult
bigBody = rng > 0 and body >= rng * bodyPct
volSpk  = not useVol or volume >= volMa * volMult

// -----------------------------------------------------------------------------
// MARKET STRUCTURE  (BOS / CHOCH)
// -----------------------------------------------------------------------------
ph = ta.pivothigh(high, pivLen, pivLen)
pl = ta.pivotlow(low,   pivLen, pivLen)

var float lastPH = na
var float lastPL = na
var int   bias   = 0

if not na(ph)
    lastPH := ph
if not na(pl)
    lastPL := pl

bosUp = not na(lastPH) and close > lastPH and close[1] <= lastPH
bosDn = not na(lastPL) and close < lastPL and close[1] >= lastPL
chUp  = bosUp and bias == -1
chDn  = bosDn and bias ==  1
if bosUp
    bias := 1
if bosDn
    bias := -1

bullStruct = bosUp or chUp
bearStruct = bosDn or chDn

// -----------------------------------------------------------------------------
// 3-CANDLE FAIR VALUE GAP
// -----------------------------------------------------------------------------
bullFVG = low  > high[2]
bearFVG = high < low[2]

// -----------------------------------------------------------------------------
// LIQUIDITY SWEEP WICK
// -----------------------------------------------------------------------------
demWick = not useWick or (rng > 0 and dnWick >= rng * wickPct)
supWick = not useWick or (rng > 0 and upWick >= rng * wickPct)

// -----------------------------------------------------------------------------
// CONFLUENCE
// -----------------------------------------------------------------------------
vwapV = ta.vwap(hlc3)
ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)

pdh = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_off)
pdl = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_off)
pdc = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_off)

pivot  = (pdh + pdl + pdc) / 3.0
bcLine = (pdh + pdl) / 2.0
tcLine = (pivot - bcLine) + pivot
cprTop = math.max(tcLine, bcLine)
cprBot = math.min(tcLine, bcLine)

inCPR(_p)       => _p <= cprTop and _p >= cprBot
nearLvl(_p, _l) => math.abs(_p - _l) <= atr * 0.5

vwapDem = not useVWAP or close >= vwapV
vwapSup = not useVWAP or close <= vwapV
emaDem  = not useEMA  or ema20 > ema50
emaSup  = not useEMA  or ema20 < ema50
pdhlDem = not usePDHL or nearLvl(low,  pdl)
pdhlSup = not usePDHL or nearLvl(high, pdh)
cprDem  = not useCPR  or inCPR(low)  or nearLvl(low,  cprBot)
cprSup  = not useCPR  or inCPR(high) or nearLvl(high, cprTop)

htfC    = request.security(syminfo.tickerid, htfRes, close[1], lookahead=barmerge.lookahead_off)
htfO    = request.security(syminfo.tickerid, htfRes, open[1],  lookahead=barmerge.lookahead_off)
htfBull = htfC > htfO
htfBear = htfC < htfO

// -----------------------------------------------------------------------------
// ZONE QUALIFICATION  (score-based: core required + N extra confirmations)
// -----------------------------------------------------------------------------
volPass     = volume >= volMa * volMult
demWickPass = rng > 0 and dnWick >= rng * wickPct
supWickPass = rng > 0 and upWick >= rng * wickPct

scoreDem = 0
scoreDem += (useVol  and volPass)     ? 1 : 0
scoreDem += (useFVG  and bullFVG)     ? 1 : 0
scoreDem += (useBOS  and bullStruct)  ? 1 : 0
scoreDem += (useWick and demWickPass) ? 1 : 0

scoreSup = 0
scoreSup += (useVol  and volPass)     ? 1 : 0
scoreSup += (useFVG  and bearFVG)     ? 1 : 0
scoreSup += (useBOS  and bearStruct)  ? 1 : 0
scoreSup += (useWick and supWickPass) ? 1 : 0

baseDem = barstate.isconfirmed and inSess and displ and bigBody and bullBar
baseSup = barstate.isconfirmed and inSess and displ and bigBody and bearBar

isDemand = baseDem and scoreDem >= minConf and vwapDem and emaDem and pdhlDem and cprDem
isSupply = baseSup and scoreSup >= minConf and vwapSup and emaSup and pdhlSup and cprSup

isSuperDem = isDemand and bullStruct and bullFVG and volPass and demWickPass and (not useHTF or htfBull)
isSuperSup = isSupply and bearStruct and bearFVG and volPass and supWickPass and (not useHTF or htfBear)

// -----------------------------------------------------------------------------
// ZONE STORAGE
// -----------------------------------------------------------------------------
type Zone
    box   bx
    line  midL
    label lbl
    float top
    float bot
    int   created
    bool  isSuper
    bool  isDem
    bool  touched
    bool  alive

var array<Zone> zones = array.new<Zone>()

f_make(bool _dem, bool _sup, float _top, float _bot) =>
    fcol = _dem ? (_sup ? sDemFill : demFill) : (_sup ? sSupFill : supFill)
    bcol = _dem ? (_sup ? sDemEdge : demEdge) : (_sup ? sSupEdge : supEdge)
    rx   = extendRight ? bar_index + 500 : bar_index + 30
    ext  = extendRight ? extend.right : extend.none
    bx   = box.new(bar_index, _top, rx, _bot, border_color=bcol, border_width=2, bgcolor=fcol, extend=ext)
    mid  = (_top + _bot) / 2.0
    line ml = na
    if showMid
        ml := line.new(bar_index, mid, rx, mid, color=color.new(bcol, 30), style=line.style_dotted, extend=ext)
    label lb = na
    if showTxt
        txt = (_dem ? demTxt : supTxt) + (_sup ? "  *SUPER" : "")
        sty = _dem ? label.style_label_up : label.style_label_down
        yy  = _dem ? _bot : _top
        lb := label.new(bar_index, yy, txt, style=sty, color=color.new(bcol, 0), textcolor=color.white, size=size.small)
    Zone.new(bx, ml, lb, _top, _bot, bar_index, _sup, _dem, false, true)

f_kill(Zone z) =>
    box.delete(z.bx)
    if not na(z.midL)
        line.delete(z.midL)
    if not na(z.lbl)
        label.delete(z.lbl)
    z.alive := false

f_capSide(bool _dem) =>
    cnt = 0
    for i = 0 to array.size(zones) - 1
        zi = array.get(zones, i)
        if zi.alive and zi.isDem == _dem
            cnt += 1
    while cnt > maxPerSide
        for i = 0 to array.size(zones) - 1
            zj = array.get(zones, i)
            if zj.alive and zj.isDem == _dem
                f_kill(zj)
                array.set(zones, i, zj)
                cnt -= 1
                break

f_add(bool _dem, bool _sup, float _top, float _bot) =>
    z = f_make(_dem, _sup, _top, _bot)
    array.push(zones, z)
    f_capSide(_dem)

// -----------------------------------------------------------------------------
// BASE CANDLE DETECTION (zone origin)
//   Walks back from bar[1]; counts consecutive small-body small-range candles.
//   The displacement candle is bar[0]. Returns 0..maxBaseBars.
// -----------------------------------------------------------------------------
f_baseLen() =>
    n = 0
    cont = true
    for k = 1 to maxBaseBars
        r = high[k] - low[k]
        b = math.abs(close[k] - open[k])
        ok = r > 0 and b <= r * baseBodyPct and r <= atr * baseRngMult
        if ok and cont
            n += 1
        else
            cont := false
    n

f_baseHigh(int _n) =>
    h = high[1]
    if _n >= 2
        for k = 2 to _n
            h := math.max(h, high[k])
    h

f_baseLow(int _n) =>
    l = low[1]
    if _n >= 2
        for k = 2 to _n
            l := math.min(l, low[k])
    l

// Reject a new zone if it overlaps an existing alive same-side zone
f_overlapsExisting(bool _dem, float _t, float _b) =>
    hit = false
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            zi = array.get(zones, i)
            if zi.alive and zi.isDem == _dem
                if _t >= zi.bot and _b <= zi.top
                    hit := true
                    break
    hit

// -----------------------------------------------------------------------------
// CREATE NEW ZONES  -  zone is anchored to the base candle(s) before the move
// -----------------------------------------------------------------------------
bLen = useBase ? f_baseLen() : 0
basePresent = (not useBase) or bLen >= 1

if isDemand and basePresent
    topZ = useBase ? f_baseHigh(bLen) : math.max(open, close)
    botZ = useBase ? f_baseLow(bLen)  : low
    if (not noOverlap) or (not f_overlapsExisting(true, topZ, botZ))
        f_add(true, isSuperDem, topZ, botZ)

if isSupply and basePresent
    topZ = useBase ? f_baseHigh(bLen) : high
    botZ = useBase ? f_baseLow(bLen)  : math.min(open, close)
    if (not noOverlap) or (not f_overlapsExisting(false, topZ, botZ))
        f_add(false, isSuperSup, topZ, botZ)

// -----------------------------------------------------------------------------
// ZONE MANAGEMENT
// -----------------------------------------------------------------------------
isNewDay = ta.change(time("D")) != 0

var bool fireDemTouch = false
var bool fireSupTouch = false
var bool fireDemEntry = false
var bool fireSupEntry = false
fireDemTouch := false
fireSupTouch := false
fireDemEntry := false
fireSupEntry := false

if array.size(zones) > 0
    for i = 0 to array.size(zones) - 1
        z = array.get(zones, i)
        if not z.alive
            continue

        if intraOnly and isNewDay and bar_index > z.created
            f_kill(z)
            array.set(zones, i, z)
            continue

        bad = false
        if invalidOnClose and z.isDem and close < z.bot
            bad := true
        if invalidOnClose and (not z.isDem) and close > z.top
            bad := true
        if bad
            box.set_bgcolor(z.bx, color.new(color.gray, 90))
            box.set_border_color(z.bx, color.new(color.gray, 50))
            if not na(z.midL)
                line.delete(z.midL)
            z.alive := false
            array.set(zones, i, z)
            continue

        touchedNow = false
        if z.isDem and low <= z.top and high >= z.bot
            touchedNow := true
        if (not z.isDem) and high >= z.bot and low <= z.top
            touchedNow := true

        if touchedNow and not z.touched
            z.touched := true
            if z.isDem
                fireDemTouch := true
            else
                fireSupTouch := true

            rejBull = z.isDem       and close > open and dnWick >= rng * wickPct
            rejBear = (not z.isDem) and close < open and upWick >= rng * wickPct

            if showEntry and rejBull
                label.new(bar_index, low, "BUY", style=label.style_label_up, color=color.new(sDemEdge, 0), textcolor=color.white, size=size.small)
                if showSLTP
                    sl = z.bot
                    tp = close + (close - sl) * rrTarget
                    line.new(bar_index, sl, bar_index + 25, sl, color=color.new(color.red, 0),   style=line.style_dashed)
                    line.new(bar_index, tp, bar_index + 25, tp, color=color.new(color.green, 0), style=line.style_dashed)
                fireDemEntry := true

            if showEntry and rejBear
                label.new(bar_index, high, "SELL", style=label.style_label_down, color=color.new(sSupEdge, 0), textcolor=color.white, size=size.small)
                if showSLTP
                    sl = z.top
                    tp = close - (sl - close) * rrTarget
                    line.new(bar_index, sl, bar_index + 25, sl, color=color.new(color.red, 0),   style=line.style_dashed)
                    line.new(bar_index, tp, bar_index + 25, tp, color=color.new(color.green, 0), style=line.style_dashed)
                fireSupEntry := true

        if alertNear and not z.touched
            buf = (z.top - z.bot) * nearPct
            if z.isDem and low <= z.top + buf and low > z.top
                alert("Price approaching Institutional Demand Zone", alert.freq_once_per_bar)
            if (not z.isDem) and high >= z.bot - buf and high < z.bot
                alert("Price approaching Institutional Supply Zone", alert.freq_once_per_bar)

        if freshOnly and z.touched and z.alive
            box.set_bgcolor(z.bx, color.new(color.gray, 92))

        array.set(zones, i, z)

// -----------------------------------------------------------------------------
// ALERTS
// -----------------------------------------------------------------------------
if alertTouch and fireDemTouch
    alert("Demand zone TOUCHED  -  watch for bullish reaction", alert.freq_once_per_bar)
if alertTouch and fireSupTouch
    alert("Supply zone TOUCHED  -  watch for bearish reaction", alert.freq_once_per_bar)
if alertEntry and fireDemEntry
    alert("BUY signal  -  rejection inside Demand zone",  alert.freq_once_per_bar)
if alertEntry and fireSupEntry
    alert("SELL signal  -  rejection inside Supply zone", alert.freq_once_per_bar)

alertcondition(fireDemTouch, "Demand Touch", "Demand zone touched - bullish setup")
alertcondition(fireSupTouch, "Supply Touch", "Supply zone touched - bearish setup")
alertcondition(fireDemEntry, "BUY Entry",    "BUY rejection in demand zone")
alertcondition(fireSupEntry, "SELL Entry",   "SELL rejection in supply zone")

// -----------------------------------------------------------------------------
// CONFLUENCE OVERLAYS
// -----------------------------------------------------------------------------
plot(useVWAP ? vwapV  : na, "VWAP",      color=color.new(color.orange,  0))
plot(useEMA  ? ema20  : na, "EMA 20",    color=color.new(color.yellow,  0))
plot(useEMA  ? ema50  : na, "EMA 50",    color=color.new(color.aqua,    0))
plot(usePDHL ? pdh    : na, "PDH",       color=color.new(color.gray,   20), style=plot.style_linebr)
plot(usePDHL ? pdl    : na, "PDL",       color=color.new(color.gray,   20), style=plot.style_linebr)
plot(useCPR  ? pivot  : na, "CPR Pivot", color=color.new(color.fuchsia,30))
plot(useCPR  ? cprTop : na, "CPR TC",    color=color.new(color.fuchsia,50))
plot(useCPR  ? cprBot : na, "CPR BC",    color=color.new(color.fuchsia,50))
