//@version=5
// =============================================================================
//  Early Move Catcher  -  "Ready to Fly" Pre-Breakout Signal
//  Standalone indicator (do NOT merge with Institutional S/D Zones).
//  Catches early moves on any script (stocks / index / FX / crypto) by
//  detecting the rare moment when ALL of the following align:
//      1. Volatility squeeze   (BB width inside Keltner -> coil)
//      2. Range compression    (NR7 / inside-bar cluster)
//      3. Volume dry-up then pop (accumulation / distribution print)
//      4. Momentum loaded      (RSI mid-zone curling, MACD hist flip)
//      5. Liquidity sweep ready (price pinned to a recent pivot edge)
//  When all gates pass -> "BUY READY" / "SELL READY" tag is plotted.
//  Side is inferred from where price is coiled relative to fast EMA & VWAP;
//  if direction is ambiguous, a neutral "FLY READY" is shown.
// =============================================================================
indicator("Early Move Catcher [Ready to Fly]",
     shorttitle="EarlyMove",
     overlay=true,
     max_labels_count=500,
     max_lines_count=200,
     max_boxes_count=200)

// -----------------------------------------------------------------------------
//  INPUTS
// -----------------------------------------------------------------------------
grpCore   = "Core Engine"
bbLen     = input.int(20,   "BB / Keltner Length",   minval=5,  group=grpCore)
bbMult    = input.float(2.0,"BB Std-Dev Mult",       minval=0.5,step=0.1, group=grpCore)
kcMult    = input.float(1.5,"Keltner ATR Mult",      minval=0.5,step=0.1, group=grpCore)
nrLook    = input.int(7,    "NR-N Lookback",         minval=3,  group=grpCore)
volLen    = input.int(20,   "Volume MA Length",      minval=5,  group=grpCore)
dryMult   = input.float(0.8,"Volume Dry-up <= MA x", minval=0.1,step=0.05,group=grpCore)
popMult   = input.float(1.4,"Volume Pop >= MA x",    minval=1.0,step=0.1, group=grpCore)
rsiLen    = input.int(14,   "RSI Length",            minval=2,  group=grpCore)
rsiLow    = input.int(40,   "RSI Lower Coil",        group=grpCore)
rsiHigh   = input.int(60,   "RSI Upper Coil",        group=grpCore)
pivLen    = input.int(10,   "Pivot Lookback",        minval=2,  group=grpCore)
pinPct    = input.float(0.5,"Pin to Pivot (% of ATR)", minval=0.1,step=0.1, group=grpCore)

grpDir    = "Direction Bias"
emaFast   = input.int(8,    "Fast EMA",              minval=2, group=grpDir)
emaSlow   = input.int(21,   "Slow EMA",              minval=5, group=grpDir)
useVwap   = input.bool(true,"Use VWAP for bias",     group=grpDir)

grpVis    = "Visuals & Alerts"
showSqz   = input.bool(true,"Highlight Squeeze Bars",   group=grpVis)
showLbl   = input.bool(true,"Show Ready Labels",        group=grpVis)
showProb  = input.bool(true,"Show Probability Score",   group=grpVis)
alertOn   = input.bool(true,"Enable Alerts",            group=grpVis)

// -----------------------------------------------------------------------------
//  CORE CALCS
// -----------------------------------------------------------------------------
atr   = ta.atr(bbLen)
basis = ta.sma(close, bbLen)
dev   = ta.stdev(close, bbLen)
bbU   = basis + bbMult * dev
bbL   = basis - bbMult * dev
kcU   = basis + kcMult * atr
kcL   = basis - kcMult * atr

// 1. Squeeze: BB inside Keltner -> volatility coil
squeeze = (bbU < kcU) and (bbL > kcL)

// 2. Range compression: NR-N (today's range smallest in N bars)
rng     = high - low
nrN     = rng <= ta.lowest(rng, nrLook)
inside  = (high <= high[1]) and (low >= low[1])
compr   = nrN or inside

// 3. Volume profile: dry-up over last few bars, then current/prev pop
vMA       = ta.sma(volume, volLen)
dryRecent = ta.sma(volume, 3) <= vMA * dryMult
popNow    = volume >= vMA * popMult
volReady  = dryRecent and popNow

// 4. Momentum loaded: RSI in coil zone & turning, MACD hist flips toward zero
rsi       = ta.rsi(close, rsiLen)
rsiCoil   = rsi >= rsiLow and rsi <= rsiHigh
[macd, sig, hist] = ta.macd(close, 12, 26, 9)
histFlip  = (hist > hist[1] and hist[1] <= hist[2]) or (hist < hist[1] and hist[1] >= hist[2])
momReady  = rsiCoil and histFlip

// 5. Liquidity / pin to pivot
ph = ta.pivothigh(high, pivLen, pivLen)
pl = ta.pivotlow(low,  pivLen, pivLen)
var float lastPH = na
var float lastPL = na
if not na(ph)
    lastPH := ph
if not na(pl)
    lastPL := pl
pinUp   = not na(lastPH) and math.abs(high - lastPH) <= atr * pinPct
pinDn   = not na(lastPL) and math.abs(low  - lastPL) <= atr * pinPct
pinned  = pinUp or pinDn

// -----------------------------------------------------------------------------
//  DIRECTION BIAS
// -----------------------------------------------------------------------------
ef = ta.ema(close, emaFast)
es = ta.ema(close, emaSlow)
vw = useVwap ? ta.vwap(hlc3) : basis

biasUp = close > ef and ef > es and close >= vw
biasDn = close < ef and ef < es and close <= vw

// -----------------------------------------------------------------------------
//  PROBABILITY SCORE  (0..100)
//  Each gate contributes; >= 80 fires the "Ready to Fly" signal.
// -----------------------------------------------------------------------------
score = 0
score += squeeze  ? 25 : 0
score += compr    ? 20 : 0
score += volReady ? 25 : 0
score += momReady ? 15 : 0
score += pinned   ? 15 : 0

ready = score >= 80

buyReady  = ready and (biasUp or pinUp)
sellReady = ready and (biasDn or pinDn) and not buyReady
flyReady  = ready and not buyReady and not sellReady

// -----------------------------------------------------------------------------
//  PLOTS
// -----------------------------------------------------------------------------
plot(ef, "EMA Fast", color=color.new(color.aqua, 0))
plot(es, "EMA Slow", color=color.new(color.orange, 0))
p1 = plot(bbU, "BB Upper", color=color.new(color.gray, 70))
p2 = plot(bbL, "BB Lower", color=color.new(color.gray, 70))
fill(p1, p2, color=showSqz and squeeze ? color.new(color.yellow, 80) : na)

plotshape(showLbl and buyReady,  title="BUY READY",
     style=shape.labelup,   location=location.belowbar,
     color=color.new(color.lime, 0), textcolor=color.black,
     text="BUY READY", size=size.small)

plotshape(showLbl and sellReady, title="SELL READY",
     style=shape.labeldown, location=location.abovebar,
     color=color.new(color.red, 0),  textcolor=color.white,
     text="SELL READY", size=size.small)

plotshape(showLbl and flyReady,  title="FLY READY",
     style=shape.diamond,   location=location.absolute,
     color=color.new(color.fuchsia, 0),
     size=size.tiny)

if showProb and ready
    label.new(bar_index, high + atr * 0.5,
         text="P=" + str.tostring(score) + "%",
         style=label.style_label_down,
         color=color.new(color.black, 20),
         textcolor=color.yellow,
         size=size.tiny)

bgcolor(showSqz and squeeze ? color.new(color.yellow, 92) : na, title="Squeeze BG")

// -----------------------------------------------------------------------------
//  ALERTS
// -----------------------------------------------------------------------------
alertcondition(buyReady,  title="Early Move - BUY READY",
     message="EarlyMove: BUY READY on {{ticker}} @ {{close}} (P>=80%)")
alertcondition(sellReady, title="Early Move - SELL READY",
     message="EarlyMove: SELL READY on {{ticker}} @ {{close}} (P>=80%)")
alertcondition(flyReady,  title="Early Move - FLY READY (any side)",
     message="EarlyMove: FLY READY on {{ticker}} @ {{close}} (P>=80%)")

if alertOn and buyReady
    alert("EarlyMove BUY READY " + syminfo.ticker, alert.freq_once_per_bar_close)
if alertOn and sellReady
    alert("EarlyMove SELL READY " + syminfo.ticker, alert.freq_once_per_bar_close)
if alertOn and flyReady
    alert("EarlyMove FLY READY " + syminfo.ticker, alert.freq_once_per_bar_close)
