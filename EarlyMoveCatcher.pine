//@version=5
// =============================================================================
//  AI Precision Reversal Catcher  [NSE Intraday]
//  Standalone, non-repainting (signals confirm only on bar close), Pine v5
//
//  Why this avoids the "SL hit" problem the breakout version had:
//  ─────────────────────────────────────────────────────────────────
//  • It does NOT chase breakouts. Breakouts retest → tight SL gets hit.
//  • It waits for price to push INTO a real demand / supply zone, then
//    prints a BUY / SELL only when the bar CLOSES back out of the zone
//    (engulfing, hammer, pin-bar with strong rejection wick + volume).
//  • Stop-loss is anchored to the signal candle's own wick + tick buffer,
//    not a generic ATR multiple — the SL only hits if the rejection
//    physically fails on price.
//  • Targets are real chart structure (opposite zone / prior swing /
//    VWAP), not made-up R-multiples.
//  • Chop filter (ADX) blocks signals in sideways tape where wicks fail.
//  • HTF (15m) EMA20/50 trend filter — counter-trend trades only allowed
//    at deep zones, with-trend trades preferred.
//
//  What you get on chart:
//    • Demand (green) and Supply (red) zone boxes from real swings
//    • BUY / SELL labels printed on the exact rejection candle
//    • Auto Entry / SL / Target lines drawn from that candle
//    • Win-stat / live state dashboard
// =============================================================================
indicator("AI Precision Reversal Catcher [NSE Intraday]",
     shorttitle="AI Reversal",
     overlay=true,
     max_boxes_count=500,
     max_lines_count=500,
     max_labels_count=500)

// ─── INPUTS ────────────────────────────────────────────────────────────────
gZone = "Zone Detection"
pivLen   = input.int(8,  "Swing Pivot Length", minval=3, group=gZone,
     tooltip="Higher = stronger zones, fewer signals")
zoneATR  = input.float(0.6,"Zone Width (ATR x)", minval=0.1, step=0.1, group=gZone)
zoneKeep = input.int(6,  "Max Active Zones (per side)", minval=2, group=gZone)
zoneTouchMax = input.int(2, "Invalidate after N touches", minval=1, group=gZone)

gCandle = "Rejection Candle Filter"
minWickRatio = input.float(0.55,"Min Rejection-Wick / Range", minval=0.3, step=0.05, group=gCandle,
     tooltip="0.55 = wick must be >= 55% of the bar's range")
maxBodyRatio = input.float(0.40,"Max Body / Range",          minval=0.1, step=0.05, group=gCandle)
needEngulf   = input.bool(false,"Require Engulfing OR Pin",  group=gCandle,
     tooltip="If on, only engulfing or pin-bar pass; if off, hammer/shooting-star also pass")
volLen   = input.int(20, "Volume MA Length",  minval=5, group=gCandle)
volMult  = input.float(1.3,"Volume Spike x MA", minval=1.0, step=0.1, group=gCandle)

gFilt = "Trend & Chop Filter"
useHTF   = input.bool(true,    "Use HTF Trend Filter",      group=gFilt)
htfTF    = input.timeframe("15","HTF Timeframe",            group=gFilt)
htfFast  = input.int(20, "HTF Fast EMA", minval=5,  group=gFilt)
htfSlow  = input.int(50, "HTF Slow EMA", minval=10, group=gFilt)
useADX   = input.bool(true, "Skip Chop (ADX filter)",       group=gFilt)
adxLen   = input.int(14, "ADX Length", minval=5, group=gFilt)
adxMin   = input.float(18,"Min ADX to allow signal", minval=10, step=1, group=gFilt)

gSes = "NSE Session (IST)"
useSession = input.bool(true,"Restrict to NSE session", group=gSes)
sessTrade  = input.session("0930-1500","Tradable Window", group=gSes)
tz         = "Asia/Kolkata"

gRisk = "Risk / Targets"
slBufferTicks = input.float(2.0, "SL Buffer (ticks)", minval=0, step=0.5, group=gRisk,
     tooltip="Extra buffer beyond signal-candle wick")
useStructTarget = input.bool(true,"Target = next structure level", group=gRisk)
fallbackR1 = input.float(1.0,"Fallback T1 R-Multiple", minval=0.5, step=0.1, group=gRisk)
fallbackR2 = input.float(2.0,"Fallback T2 R-Multiple", minval=0.5, step=0.1, group=gRisk)
planLen   = input.int(40, "Plan Lines Length (bars)", minval=10, group=gRisk)

gVis = "Visuals"
showZones = input.bool(true,"Show Demand / Supply Zones", group=gVis)
showPlan  = input.bool(true,"Show Trade Plan (E/SL/T1/T2)", group=gVis)
showDash  = input.bool(true,"Show Dashboard",              group=gVis)
showVWAP  = input.bool(true,"Show Anchored VWAP",          group=gVis)

// ─── HELPERS ───────────────────────────────────────────────────────────────
atr     = ta.atr(14)
mintick = syminfo.mintick
rngBar  = high - low
body    = math.abs(close - open)
upWick  = high - math.max(close, open)
loWick  = math.min(close, open) - low

inSession = not useSession or not na(time(timeframe.period, sessTrade, tz))
newDay    = ta.change(time("D")) != 0

[vwap, _vu, _vl] = ta.vwap(hlc3, newDay, 1.0)

// HTF trend
htfEmaF = request.security(syminfo.tickerid, htfTF, ta.ema(close, htfFast), lookahead=barmerge.lookahead_off)
htfEmaS = request.security(syminfo.tickerid, htfTF, ta.ema(close, htfSlow), lookahead=barmerge.lookahead_off)
htfClose= request.security(syminfo.tickerid, htfTF, close, lookahead=barmerge.lookahead_off)
htfUp = htfClose > htfEmaF and htfEmaF > htfEmaS
htfDn = htfClose < htfEmaF and htfEmaF < htfEmaS

// ADX
[diPlus, diMinus, adx] = ta.dmi(adxLen, adxLen)
trendOk = not useADX or adx >= adxMin

// ─── ZONE BUILDER ──────────────────────────────────────────────────────────
ph = ta.pivothigh(high, pivLen, pivLen)
pl = ta.pivotlow(low,  pivLen, pivLen)

type Zone
    box   bx
    float top
    float bot
    int   touches
    bool  isDemand

var array<Zone> demandZones = array.new<Zone>()
var array<Zone> supplyZones = array.new<Zone>()

newDemand(float price, float a) =>
    bot = price - a * zoneATR * 0.5
    top = price + a * zoneATR * 0.5
    bx  = showZones ? box.new(bar_index - pivLen, top, bar_index + 50, bot,
              border_color=color.new(color.green, 40),
              bgcolor=color.new(color.green, 85), extend=extend.right) : na
    Zone.new(bx, top, bot, 0, true)

newSupply(float price, float a) =>
    bot = price - a * zoneATR * 0.5
    top = price + a * zoneATR * 0.5
    bx  = showZones ? box.new(bar_index - pivLen, top, bar_index + 50, bot,
              border_color=color.new(color.red, 40),
              bgcolor=color.new(color.red, 85), extend=extend.right) : na
    Zone.new(bx, top, bot, 0, false)

if not na(pl)
    z = newDemand(pl, atr[pivLen])
    array.unshift(demandZones, z)
    while array.size(demandZones) > zoneKeep
        old = array.pop(demandZones)
        if not na(old.bx)
            box.delete(old.bx)

if not na(ph)
    z = newSupply(ph, atr[pivLen])
    array.unshift(supplyZones, z)
    while array.size(supplyZones) > zoneKeep
        old = array.pop(supplyZones)
        if not na(old.bx)
            box.delete(old.bx)

// Zone interaction lookups
inDemand = false
demTop = 0.0
demBot = 0.0
if array.size(demandZones) > 0
    for i = 0 to array.size(demandZones) - 1
        z = array.get(demandZones, i)
        if z.touches < zoneTouchMax and low <= z.top and low >= z.bot - atr * 0.2
            inDemand := true
            demTop := z.top
            demBot := z.bot
            z.touches += 1
            break

inSupply = false
supTop = 0.0
supBot = 0.0
if array.size(supplyZones) > 0
    for i = 0 to array.size(supplyZones) - 1
        z = array.get(supplyZones, i)
        if z.touches < zoneTouchMax and high >= z.bot and high <= z.top + atr * 0.2
            inSupply := true
            supTop := z.top
            supBot := z.bot
            z.touches += 1
            break

// ─── REJECTION CANDLE PATTERNS ─────────────────────────────────────────────
isBullEngulf = close > open and close[1] < open[1] and close >= open[1] and open <= close[1]
isBearEngulf = close < open and close[1] > open[1] and close <= open[1] and open >= close[1]
isHammer     = rngBar > 0 and loWick / rngBar >= minWickRatio and body / rngBar <= maxBodyRatio and close >= open
isShooting   = rngBar > 0 and upWick / rngBar >= minWickRatio and body / rngBar <= maxBodyRatio and close <= open
isPinBull    = rngBar > 0 and loWick >= rngBar * minWickRatio and close > (high + low) / 2
isPinBear    = rngBar > 0 and upWick >= rngBar * minWickRatio and close < (high + low) / 2

bullCandle = needEngulf ? (isBullEngulf or isPinBull) : (isBullEngulf or isHammer or isPinBull)
bearCandle = needEngulf ? (isBearEngulf or isPinBear) : (isBearEngulf or isShooting or isPinBear)

vMA      = ta.sma(volume, volLen)
volSpike = volume >= vMA * volMult

// ─── ENTRY GATES ───────────────────────────────────────────────────────────
buyOk  = inSession and trendOk and inDemand and bullCandle and volSpike and (not useHTF or not htfDn)
sellOk = inSession and trendOk and inSupply and bearCandle and volSpike and (not useHTF or not htfUp)

// confirm only on bar close → no repaint
buySignal  = barstate.isconfirmed and buyOk
sellSignal = barstate.isconfirmed and sellOk

// ─── TRADE PLAN ────────────────────────────────────────────────────────────
nextSupply() =>
    float t = na
    if array.size(supplyZones) > 0
        for i = 0 to array.size(supplyZones) - 1
            z = array.get(supplyZones, i)
            if z.bot > close
                t := z.bot
                break
    t

nextDemand() =>
    float t = na
    if array.size(demandZones) > 0
        for i = 0 to array.size(demandZones) - 1
            z = array.get(demandZones, i)
            if z.top < close
                t := z.top
                break
    t

var float entryPx = na
var float slPx    = na
var float t1Px    = na
var float t2Px    = na
var int   side    = 0
var int   wins    = 0
var int   losses  = 0
var int   active  = 0   // 0 flat, 1 long, -1 short

if buySignal
    entryPx := close
    slPx    := low - slBufferTicks * mintick
    rUnit   = entryPx - slPx
    structT = nextSupply()
    t1Px    := useStructTarget and not na(structT) ? structT : entryPx + rUnit * fallbackR1
    t2Px    := entryPx + rUnit * fallbackR2
    side    := 1
    active  := 1

if sellSignal
    entryPx := close
    slPx    := high + slBufferTicks * mintick
    rUnit   = slPx - entryPx
    structT = nextDemand()
    t1Px    := useStructTarget and not na(structT) ? structT : entryPx - rUnit * fallbackR1
    t2Px    := entryPx - rUnit * fallbackR2
    side    := -1
    active  := -1

// rough stat-tracking on chart bars (for dashboard only)
if active == 1
    if low <= slPx
        losses += 1
        active := 0
    else if high >= t1Px
        wins += 1
        active := 0
if active == -1
    if high >= slPx
        losses += 1
        active := 0
    else if low <= t1Px
        wins += 1
        active := 0

if showPlan and (buySignal or sellSignal)
    line.new(bar_index, entryPx, bar_index + planLen, entryPx,
         color=color.new(color.blue, 0), width=2)
    line.new(bar_index, slPx,    bar_index + planLen, slPx,
         color=color.new(color.red, 0),  width=2, style=line.style_dashed)
    line.new(bar_index, t1Px,    bar_index + planLen, t1Px,
         color=color.new(color.green, 20), width=2)
    line.new(bar_index, t2Px,    bar_index + planLen, t2Px,
         color=color.new(color.green, 0), width=3)
    label.new(bar_index + planLen, entryPx, "ENTRY " + str.tostring(entryPx, "#.##"),
         style=label.style_label_left, color=color.new(color.blue, 70),
         textcolor=color.white, size=size.small)
    label.new(bar_index + planLen, slPx,    "SL "    + str.tostring(slPx, "#.##"),
         style=label.style_label_left, color=color.new(color.red, 70),
         textcolor=color.white, size=size.small)
    label.new(bar_index + planLen, t1Px,    "T1 "    + str.tostring(t1Px, "#.##"),
         style=label.style_label_left, color=color.new(color.green, 60),
         textcolor=color.white, size=size.small)
    label.new(bar_index + planLen, t2Px,    "T2 "    + str.tostring(t2Px, "#.##"),
         style=label.style_label_left, color=color.new(color.green, 40),
         textcolor=color.white, size=size.small)

// ─── PLOTS ─────────────────────────────────────────────────────────────────
plot(showVWAP ? vwap : na, "VWAP", color=color.new(color.yellow, 0), linewidth=2)

plotshape(buySignal,  "BUY",  shape.labelup,   location.belowbar,
     color=color.new(color.lime, 0), text="BUY",  textcolor=color.black, size=size.normal)
plotshape(sellSignal, "SELL", shape.labeldown, location.abovebar,
     color=color.new(color.red, 0),  text="SELL", textcolor=color.white, size=size.normal)

// Zone-touch highlight
bgcolor(inDemand ? color.new(color.green, 92) : na, title="In Demand")
bgcolor(inSupply ? color.new(color.red,   92) : na, title="In Supply")

// ─── DASHBOARD ─────────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 8, border_width=1)
if showDash and barstate.islast
    total = wins + losses
    wr    = total > 0 ? math.round(wins * 100.0 / total) : 0
    table.cell(dash, 0, 0, "AI Reversal", bgcolor=color.new(color.navy, 0), text_color=color.white,  text_size=size.normal)
    table.cell(dash, 1, 0, syminfo.ticker, bgcolor=color.new(color.navy, 0), text_color=color.yellow, text_size=size.normal)
    table.cell(dash, 0, 1, "HTF " + htfTF, bgcolor=color.new(color.gray, 60), text_color=color.white)
    table.cell(dash, 1, 1, htfUp ? "UP" : htfDn ? "DOWN" : "FLAT",
         bgcolor=htfUp ? color.green : htfDn ? color.red : color.gray, text_color=color.white)
    table.cell(dash, 0, 2, "ADX", bgcolor=color.new(color.gray, 60), text_color=color.white)
    table.cell(dash, 1, 2, str.tostring(adx, "#.#"),
         bgcolor=trendOk ? color.green : color.new(color.gray, 30), text_color=color.white)
    table.cell(dash, 0, 3, "Zone", bgcolor=color.new(color.gray, 60), text_color=color.white)
    table.cell(dash, 1, 3, inDemand ? "DEMAND" : inSupply ? "SUPPLY" : "—",
         bgcolor=inDemand ? color.green : inSupply ? color.red : color.new(color.gray, 30), text_color=color.white)
    table.cell(dash, 0, 4, "Active", bgcolor=color.new(color.gray, 60), text_color=color.white)
    table.cell(dash, 1, 4, active == 1 ? "LONG" : active == -1 ? "SHORT" : "FLAT",
         bgcolor=active == 1 ? color.green : active == -1 ? color.red : color.new(color.gray, 30), text_color=color.white)
    table.cell(dash, 0, 5, "Entry", bgcolor=color.new(color.gray, 60), text_color=color.white)
    table.cell(dash, 1, 5, na(entryPx) ? "—" : str.tostring(entryPx, "#.##"), bgcolor=color.black, text_color=color.white)
    table.cell(dash, 0, 6, "Wins / Losses", bgcolor=color.new(color.gray, 60), text_color=color.white)
    table.cell(dash, 1, 6, str.tostring(wins) + " / " + str.tostring(losses), bgcolor=color.black, text_color=color.white)
    table.cell(dash, 0, 7, "WinRate", bgcolor=color.new(color.gray, 60), text_color=color.white)
    table.cell(dash, 1, 7, str.tostring(wr) + "%",
         bgcolor=wr >= 60 ? color.green : wr >= 45 ? color.orange : color.new(color.gray, 30),
         text_color=color.white)

// ─── ALERTS ────────────────────────────────────────────────────────────────
alertcondition(buySignal,  title="AI BUY",
     message='AI BUY {{ticker}} @ {{close}} — rejection from demand zone, see chart for SL / T1 / T2')
alertcondition(sellSignal, title="AI SELL",
     message='AI SELL {{ticker}} @ {{close}} — rejection from supply zone, see chart for SL / T1 / T2')

if buySignal
    alert("AI BUY " + syminfo.ticker + " @ " + str.tostring(close, "#.##") +
         " | SL " + str.tostring(slPx, "#.##") +
         " | T1 " + str.tostring(t1Px, "#.##") +
         " | T2 " + str.tostring(t2Px, "#.##"),
         alert.freq_once_per_bar_close)
if sellSignal
    alert("AI SELL " + syminfo.ticker + " @ " + str.tostring(close, "#.##") +
         " | SL " + str.tostring(slPx, "#.##") +
         " | T1 " + str.tostring(t1Px, "#.##") +
         " | T2 " + str.tostring(t2Px, "#.##"),
         alert.freq_once_per_bar_close)
